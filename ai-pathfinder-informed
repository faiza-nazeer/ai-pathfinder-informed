import tkinter as tk
from tkinter import ttk, messagebox
import random
import math
import time
from collections import deque

class Node:
    def __init__(self, x, y):
        self.x = x
        self.y = y
        self.obstacle = False
        self.parent = None
        self.g = float('inf')
        self.h = 0
        self.f = float('inf')

class DynamicPathfinder:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Dynamic Pathfinder")
       
        self.rows = 15
        self.cols = 20
        self.cell_size = 28
        
        # Colors
        self.colors = {
            'empty': 'white',
            'obstacle': 'black',
            'start': 'blue',
            'goal': 'red',
            'path': 'green',
            'visited': 'light blue',
            'frontier': 'yellow',
            'expanding': 'orange',
            'grid_line': 'gray'
        }
        
        # Create grid
        self.grid = [[Node(i, j) for j in range(self.cols)] for i in range(self.rows)]
        
        # Start and Goal
        self.start = (0, 0)
        self.goal = (self.rows-1, self.cols-1)
        
        # Algorithm settings
        self.algorithm = tk.StringVar(value="A*")
        self.heuristic = tk.StringVar(value="Manhattan")
        self.dynamic_mode = tk.BooleanVar(value=False)
        self.animation_speed = tk.DoubleVar(value=0.5)
        
        # Map generation settings
        self.obstacle_density = tk.DoubleVar(value=0.3)  # Default 30%
        
        # Pathfinding results
        self.path = []
        self.visited = []
        self.frontier = []
        self.expanding_node = None
        self.path_cost = 0
        self.nodes_visited = 0
        self.execution_time = 0
        
        # Exploration
        self.exploration_active = False
        self.exploration_id = None
        self.search_frontier = []
        self.search_visited = []
        self.search_parents = {}
        self.search_step_count = 0
        self.start_time = 0
        
        
        self.setup_gui()
        
        # Generate initial random map
        self.generate_random_map()
        
