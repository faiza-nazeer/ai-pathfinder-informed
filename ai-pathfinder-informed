        ttk.Button(action_frame, text="Reset", command=self.reset_grid, width=8).grid(row=0, column=2, padx=1)
        
        # Metrics display
        ttk.Label(control_frame, text="Metrics", font=('Arial', 10, 'bold')).grid(row=7, column=0, columnspan=2, pady=(5,2))
        
        self.metrics_text = tk.Text(control_frame, width=22, height=6, state='disabled', font=('Arial', 8))
        self.metrics_text.grid(row=8, column=0, columnspan=2, pady=2)
        
        # Quick instructions
        instructions = """
Click: L=Obstacle
R=Start(S) M=Goal(G)
        """
        ttk.Label(control_frame, text=instructions, justify=tk.LEFT, font=('Arial', 8)).grid(row=9, column=0, columnspan=2, pady=5)
        
        # Draw initial grid
        self.draw_grid()
        
        # Set window size and position
        self.root.update_idletasks()
        window_width = canvas_width + 280  # 280 for control panel
        window_height = max(canvas_height + 80, 500)  # Ensure minimum height
        self.root.geometry(f"{window_width}x{window_height}")
        self.root.minsize(700, 450)
        
    def draw_grid(self):
        """Draw the grid on canvas"""
        self.canvas.delete("all")
        
        # Draw cells
        for i in range(self.rows):
            for j in range(self.cols):
                x1 = j * self.cell_size
                y1 = i * self.cell_size
                x2 = x1 + self.cell_size
                y2 = y1 + self.cell_size
                
                # Determine cell color
                if (i, j) == self.start:
                    color = self.colors['start']
                elif (i, j) == self.goal:
                    color = self.colors['goal']
                elif self.grid[i][j].obstacle:
                    color = self.colors['obstacle']
                elif (i, j) in self.path:
                    color = self.colors['path']
                elif (i, j) == self.expanding_node:
                    color = self.colors['expanding']
                elif (i, j) in self.visited:
                    color = self.colors['visited']
                elif (i, j) in self.frontier:
                    color = self.colors['frontier']
                else:
                    color = self.colors['empty']
                
                self.canvas.create_rectangle(x1, y1, x2, y2, fill=color, outline=self.colors['grid_line'])
                
                # Add labels for Start and Goal
                if (i, j) == self.start:
                    self.canvas.create_text(x1 + self.cell_size//2, y1 + self.cell_size//2, 
                                           text="S", fill="white", font=('Arial', 10, 'bold'))
                elif (i, j) == self.goal:
                    self.canvas.create_text(x1 + self.cell_size//2, y1 + self.cell_size//2, 
                                           text="G", fill="white", font=('Arial', 10, 'bold'))
        
        self.update_metrics()
        
    def update_metrics(self):
        """Update metrics display"""
        self.metrics_text.config(state='normal')
        self.metrics_text.delete(1.0, tk.END)
        
        # Calculate elapsed time if exploration is active
        current_time = self.execution_time
        if self.exploration_active and self.start_time > 0:
            current_time = (time.time() - self.start_time) * 1000
        
        # Calculate actual obstacle density
        total_cells = self.rows * self.cols
        obstacle_count = sum(1 for i in range(self.rows) for j in range(self.cols) if self.grid[i][j].obstacle)
        actual_density = (obstacle_count / total_cells) * 100
        
        metrics = f"""Algo: {self.algorithm.get()}
Heur: {self.heuristic.get()}
Visited: {self.nodes_visited}
Frontier: {len(self.frontier)}
Cost: {self.path_cost}
Time: {current_time:.1f}ms
Step: {self.search_step_count}
Obs: {obstacle_count}({actual_density:.0f}%)"""
        
        self.metrics_text.insert(1.0, metrics)
        self.metrics_text.config(state='disabled')
        
    def left_click(self, event):
        """Left click - toggle obstacle"""
        # Adjust for canvas scrolling
        x = self.canvas.canvasx(event.x)
        y = self.canvas.canvasy(event.y)
        
        j = int(x // self.cell_size)
        i = int(y // self.cell_size)
        
        if 0 <= i < self.rows and 0 <= j < self.cols:
            if (i, j) != self.start and (i, j) != self.goal:
                self.grid[i][j].obstacle = not self.grid[i][j].obstacle
                self.clear_path()
                self.draw_grid()
    
    def right_click(self, event):
        """Right click - set start"""
        # Adjust for canvas scrolling
        x = self.canvas.canvasx(event.x)
        y = self.canvas.canvasy(event.y)
        
        j = int(x // self.cell_size)
        i = int(y // self.cell_size)
        
        if 0 <= i < self.rows and 0 <= j < self.cols:
            if not self.grid[i][j].obstacle:
                self.start = (i, j)
                self.clear_path()
                self.draw_grid()
    
    def middle_click(self, event):
        """Middle click - set goal"""
        # Adjust for canvas scrolling
        x = self.canvas.canvasx(event.x)
        y = self.canvas.canvasy(event.y)
        
        j = int(x // self.cell_size)
        i = int(y // self.cell_size)
        
        if 0 <= i < self.rows and 0 <= j < self.cols:
            if not self.grid[i][j].obstacle:
                self.goal = (i, j)
                self.clear_path()
                self.draw_grid()
    
    def generate_random_map(self):
        """Generate random obstacles with user-defined density"""
        density = self.obstacle_density.get()
        for i in range(self.rows):
            for j in range(self.cols):
                if (i, j) != self.start and (i, j) != self.goal:
                    self.grid[i][j].obstacle = random.random() < density
        self.clear_path()
        self.draw_grid()
    
    def generate_maze(self):
        """Generate a simple maze pattern"""
        self.reset_grid()
        
        # Create a simple maze pattern with walls
        for i in range(self.rows):
            for j in range(self.cols):
                if (i, j) != self.start and (i, j) != self.goal:
                    # Create a checkerboard-like pattern with some randomness
                    if (i % 3 == 0 and j % 2 == 0) or (j % 3 == 0 and i % 2 == 0):
                        if random.random() < 0.7:  # 70% chance to place wall
                            self.grid[i][j].obstacle = True
        
        # Ensure start and goal are not blocked
        self.grid[self.start[0]][self.start[1]].obstacle = False
        self.grid[self.goal[0]][self.goal[1]].obstacle = False
        
        self.clear_path()
        self.draw_grid()
    
    def generate_open_field(self):
        """Clear all obstacles"""
        for i in range(self.rows):
            for j in range(self.cols):
                self.grid[i][j].obstacle = False
        self.clear_path()
        self.draw_grid()
    
    def generate_walls(self):
        """Generate vertical and horizontal walls"""
        self.reset_grid()
        
        # Add some vertical walls
        for wall_x in [5, 10, 15]:
            for i in range(self.rows):
                if (i, wall_x) != self.start and (i, wall_x) != self.goal:
                    if random.random() < 0.8:  # 80% chance for wall segment
                        self.grid[i][wall_x].obstacle = True
        
        # Add some horizontal walls
        for wall_y in [4, 8, 12]:
            for j in range(self.cols):
                if (wall_y, j) != self.start and (wall_y, j) != self.goal:
                    if random.random() < 0.8:  # 80% chance for wall segment
                        self.grid[wall_y][j].obstacle = True
        
        # Ensure start and goal are not blocked
        self.grid[self.start[0]][self.start[1]].obstacle = False
        self.grid[self.goal[0]][self.goal[1]].obstacle = False
        
        self.clear_path()
        self.draw_grid()
    
    def reset_grid(self):
        """Remove all obstacles"""
        for i in range(self.rows):
            for j in range(self.cols):
                self.grid[i][j].obstacle = False
        self.clear_path()
        self.draw_grid()
    
    def clear_path(self):
        """Clear pathfinding results"""
        self.path = []
        self.visited = []
        self.frontier = []
        self.expanding_node = None
        self.path_cost = 0
        self.nodes_visited = 0
        self.execution_time = 0
        self.start_time = 0
        self.stop_exploration()
        self.draw_grid()
    
    def heuristic_func(self, a, b):
        """Calculate heuristic"""
        if self.heuristic.get() == "Manhattan":
            return abs(a[0] - b[0]) + abs(a[1] - b[1])
        else:  # Euclidean
            return math.sqrt((a[0] - b[0])**2 + (a[1] - b[1])**2)
    
    def get_neighbors(self, pos):
        """Get valid neighbors"""
        x, y = pos
        neighbors = []
        for dx, dy in [(0, 1), (1, 0), (0, -1), (-1, 0)]:
            nx, ny = x + dx, y + dy
            if 0 <= nx < self.rows and 0 <= ny < self.cols:
                if not self.grid[nx][ny].obstacle:
                    neighbors.append((nx, ny))
        return neighbors
    
    def start_exploration(self):
        """Start step-by-step exploration"""
        self.stop_exploration()
        self.clear_path()
        
        # Reset node values
        for i in range(self.rows):
            for j in range(self.cols):
                self.grid[i][j].parent = None
                self.grid[i][j].g = float('inf')
                self.grid[i][j].h = 0
                self.grid[i][j].f = float('inf')
        
        # Initialize search state based on algorithm
        algorithm = self.algorithm.get()
        start = self.start
        goal = self.goal
        
        if algorithm == "A*":
            self.grid[start[0]][start[1]].g = 0
            self.grid[start[0]][start[1]].h = self.heuristic_func(start, goal)
            self.grid[start[0]][start[1]].f = self.grid[start[0]][start[1]].h
            self.search_frontier = [(self.grid[start[0]][start[1]].f, start)]
        else:  # GBFS
            self.search_frontier = [(self.heuristic_func(start, goal), start)]
        
        self.search_frontier_set = {start}
        self.search_visited = []
        self.search_parents = {start: None}
        self.search_step_count = 0
        self.exploration_active = True
        self.frontier = [start]
        self.visited = []
        self.expanding_node = None
        
        # Start timing
        self.start_time = time.time()
        self.execution_time = 0
        
        # Take first step
        self.next_exploration_step()
    
    def next_exploration_step(self):
        """Perform one step of exploration"""
        if not self.exploration_active:
            return
        
        algorithm = self.algorithm.get()
        goal = self.goal
        start = self.start
        
        # Clear previous expanding node
        self.expanding_node = None
        
        if not self.search_frontier:
            # Update final time
            self.execution_time = (time.time() - self.start_time) * 1000
            messagebox.showinfo("Exploration Complete", "No path found to goal!")
            self.stop_exploration()
            return
        
        # Sort frontier
        self.search_frontier.sort()
        priority, current = self.search_frontier.pop(0)
        
        # Remove from frontier set
        if current in self.search_frontier_set:
            self.search_frontier_set.remove(current)
        
        # Skip if already visited
        if current in self.search_visited:
            self.root.after(int(self.animation_speed.get() * 1000), self.next_exploration_step)
            return
        
        # Mark as currently expanding
        self.expanding_node = current
        
        # Add to visited
        self.search_visited.append(current)
        self.visited = self.search_visited.copy()
        self.nodes_visited = len(self.visited)
        
        # Update frontier display
        self.frontier = list(self.search_frontier_set)
        
        self.search_step_count += 1
        
        # Check if goal reached
        if current == goal:
            # Reconstruct path
            path = []
            while current != start:
                path.append(current)
                current = self.search_parents[current]
            path.append(start)
            path.reverse()
            self.path = path
            self.path_cost = len(path) - 1
            
            # Update final time
            self.execution_time = (time.time() - self.start_time) * 1000
            
            self.exploration_active = False
            messagebox.showinfo("Goal Found!", f"Path found in {self.search_step_count} steps!")
            self.expanding_node = None
            self.draw_grid()
            return
        
        # Expand current node
        for neighbor in self.get_neighbors(current):
            if neighbor not in self.search_visited:
                # Update parent
                if neighbor not in self.search_parents:
                    self.search_parents[neighbor] = current
                
                # Calculate priority based on algorithm
                if algorithm == "A*":
                    new_g = self.grid[current[0]][current[1]].g + 1
                    if new_g < self.grid[neighbor[0]][neighbor[1]].g:
                        self.grid[neighbor[0]][neighbor[1]].g = new_g
                        self.grid[neighbor[0]][neighbor[1]].h = self.heuristic_func(neighbor, goal)
                        f = new_g + self.grid[neighbor[0]][neighbor[1]].h
                        
                        if neighbor not in self.search_frontier_set:
                            self.search_frontier.append((f, neighbor))
                            self.search_frontier_set.add(neighbor)
                else:  # GBFS
                    if neighbor not in self.search_frontier_set:
                        h = self.heuristic_func(neighbor, goal)
                        self.search_frontier.append((h, neighbor))
                        self.search_frontier_set.add(neighbor)
        
        # Update display
        self.draw_grid()
        
        # Schedule next step
        if self.exploration_active:
            self.exploration_id = self.root.after(int(self.animation_speed.get() * 1000), self.next_exploration_step)
    
    def stop_exploration(self):
        """Stop exploration and clear"""
        self.exploration_active = False
        if self.exploration_id:
            self.root.after_cancel(self.exploration_id)
            self.exploration_id = None
        
        # Update final time if exploration was active
        if self.start_time > 0:
            self.execution_time = (time.time() - self.start_time) * 1000
        
        self.path = []
        self.visited = []
        self.frontier = []
        self.expanding_node = None
        self.path_cost = 0
        self.nodes_visited = 0
        self.search_step_count = 0
        self.start_time = 0
        self.draw_grid()
    
    def run(self):
        """Start the application"""
        self.root.mainloop()

