        ttk.Checkbutton(control_frame, text="Dynamic Mode", variable=self.dynamic_mode).grid(row=4, column=0, columnspan=2, pady=2, sticky=tk.W)
        
        # Map Generation Controls
        map_frame = ttk.LabelFrame(control_frame, text="Map Generation", padding="3")
